<base:WindowBase
    x:Class="v2rayN.Views.AvailabilityEditWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:base="clr-namespace:v2rayN.Base"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:reactiveui="http://reactiveui.net"
    xmlns:resx="clr-namespace:ServiceLib.Resx;assembly=ServiceLib"
    xmlns:vms="clr-namespace:ServiceLib.ViewModels;assembly=ServiceLib"
    Title="编辑检测站点"
    Width="600"
    Height="500"
    x:TypeArguments="vms:AvailabilityEditViewModel"
    ShowInTaskbar="False"
    Style="{StaticResource WindowGlobal}"
    WindowStartupLocation="CenterScreen">

    <DockPanel Margin="{StaticResource Margin8}">
        <StackPanel
            Margin="{StaticResource Margin4}"
            HorizontalAlignment="Center"
            DockPanel.Dock="Bottom"
            Orientation="Horizontal">
            <Button
                x:Name="btnSave"
                Width="100"
                Content="{x:Static resx:ResUI.TbConfirm}"
                IsDefault="True"
                Style="{StaticResource DefButton}" />
            <Button
                x:Name="btnCancel"
                Width="100"
                Margin="{StaticResource MarginLeftRight8}"
                Content="{x:Static resx:ResUI.TbCancel}"
                IsCancel="true"
                Style="{StaticResource DefButton}" />
        </StackPanel>

        <ScrollViewer materialDesign:ScrollViewerAssist.IsAutoHideEnabled="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Margin="{StaticResource Margin4}" VerticalAlignment="Center" Text="站点名称" />
                <TextBox x:Name="txtDestinationName" Grid.Row="0" Grid.Column="1" Margin="{StaticResource Margin4}" Style="{StaticResource MyOutlinedTextBox}" />

                <TextBlock Grid.Row="1" Grid.Column="0" Margin="{StaticResource Margin4}" VerticalAlignment="Center" Text="检测地址 (URL)" />
                <TextBox x:Name="txtTestUrl" Grid.Row="1" Grid.Column="1" Margin="{StaticResource Margin4}" Style="{StaticResource MyOutlinedTextBox}" />

                <TextBlock Grid.Row="2" Grid.Column="0" Margin="{StaticResource Margin4}" VerticalAlignment="Center" Text="成功特征码" />
                <TextBox x:Name="txtSuccessKeywords" Grid.Row="2" Grid.Column="1" Margin="{StaticResource Margin4}" materialDesign:HintAssist.Hint="响应内容包含此字符串则视为可用" Style="{StaticResource MyOutlinedTextBox}" />

                <TextBlock Grid.Row="3" Grid.Column="0" Margin="{StaticResource Margin4}" VerticalAlignment="Center" Text="User-Agent" />
                <TextBox x:Name="txtUserAgent" Grid.Row="3" Grid.Column="1" Margin="{StaticResource Margin4}" AcceptsReturn="True" TextWrapping="Wrap" Style="{StaticResource MyOutlinedTextBox}" />

                <TextBlock Grid.Row="4" Grid.Column="0" Margin="{StaticResource Margin4}" VerticalAlignment="Center" Text="启用检测" />
                <ToggleButton x:Name="togEnable" Grid.Row="4" Grid.Column="1" HorizontalAlignment="Left" Margin="{StaticResource Margin4}" />

                <TextBlock Grid.Row="5" Grid.Column="0" Margin="{StaticResource Margin4}" VerticalAlignment="Center" Text="{x:Static resx:ResUI.LvSort}" />
                <TextBox x:Name="txtSort" Grid.Row="5" Grid.Column="1" Width="100" HorizontalAlignment="Left" Margin="{StaticResource Margin4}" Style="{StaticResource MyOutlinedTextBox}" />
            </Grid>
        </ScrollViewer>
    </DockPanel>
</base:WindowBase>
